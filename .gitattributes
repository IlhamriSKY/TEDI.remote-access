# Deterministic LF endings for source + config across platforms (no autocrlf
# churn on Windows checkouts).
*.js    text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.rs    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.conf  text eol=lf
*.service text eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.ico   binary
*.exe   binary
*.woff  binary
*.woff2 binary
