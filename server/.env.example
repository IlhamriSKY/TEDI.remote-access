# TEDI Remote Access relay - environment.
#
# Copy to `.env` next to server.js and fill in. `server/install.sh` generates
# this for you on a fresh VPS; this file documents every variable for a manual
# setup or when adding one (like Turnstile) to an existing deploy.
# Never commit your real .env - only this .example.

# Port the relay listens on (localhost only; nginx terminates TLS in front).
PORT=8788

# REQUIRED. Shared secret the host agent authenticates with. Must equal the
# extension's "Agent token" setting. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_TOKEN=replace-with-a-64-hex-secret

# REQUIRED. HMAC key for signing session cookies. Keep stable across restarts
# (a random default would invalidate every session on restart).
SESSION_SECRET=replace-with-a-64-hex-secret

# Browser login. LOGIN_PASS_HASH is "salt:hash" (hex) from `node gen-hash.js <password>`.
LOGIN_USER=admin
LOGIN_PASS_HASH=replace-with-salt:hash-from-gen-hash.js

# Set to 1 behind a reverse proxy so the login rate-limiter keys on nginx's
# X-Real-IP (X-Forwarded-For is spoofable). Without it every client buckets as
# 127.0.0.1 and 5 bad guesses lock everyone out.
TRUST_PROXY=1

# Enforce the browser WebSocket Origin (defense-in-depth vs cross-site WS
# hijacking). Must exactly equal your public origin, no trailing slash.
ALLOWED_ORIGIN=https://remote.example.com

# Optional 2FA. Set a base32 secret, add it to your authenticator app, then
# login also requires the 6-digit code.
# TOTP_SECRET=ABCDEFGHIJKLMNOP

# Optional Cloudflare Turnstile bot gate on login + change-password. Enabled only
# when BOTH are set. Create a widget at https://dash.cloudflare.com (Turnstile),
# allow your relay domain, then paste the keys here. The site key is public (sent
# to the browser); the secret NEVER leaves the server.
# TURNSTILE_SITEKEY=0xAAAAAAAA...
# TURNSTILE_SECRET=0xAAAAAAAA...
