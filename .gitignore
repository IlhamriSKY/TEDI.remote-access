# CI-built agent binaries (per os/arch). Shipped in the release zip; ignored in
# the source tree so local cargo builds don't pollute git status.
/sidecar/

# Rust build artefacts
/sidecar-src/target/

# Built extension bundle — generated from src/ by `node build.mjs`. NOT
# committed: CI (release.yml) builds it into the release .zip. Dev: npm run build.
/extension.js

# Node deps (root build tooling + client + server)
node_modules/

# Built browser SPA. Generated from client/ into server/public by
# `cd client && npm run build`. NOT committed and NOT shipped pre-built: the
# release bundles client/ SOURCE and you build it on deploy (see README). CI
# only builds it to verify the website still compiles.
/server/public/

# Release artefacts
dist/
*.zip

# Local agent config (may contain the relay token)
*.agent.json
.env

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json
